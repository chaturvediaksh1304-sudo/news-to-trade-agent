# --- Alpaca (paper account; broker AND news source, same credentials) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Risk limits (confirmed values, see CLAUDE.md Open Items) ---
MAX_POSITION_PCT=5
MAX_DAILY_TRADES=10

# --- Debate gating ---
SENTIMENT_THRESHOLD=0.3

# --- Token budget ---
DAILY_TOKEN_CAP=2000000

# --- Storage ---
DB_PATH=db/trades.db

# --- Safety: must be explicitly set to false for any order to reach Alpaca ---
DRY_RUN=true

# --- Setup / Run ---
# 1. brew install uv  (once)
# 2. uv venv --python 3.11 && uv pip install -e ".[dev]"
# 3. cp .env.example .env  and fill in keys
# 4. npx ruflo@latest init  (optional; memory falls back to local JSON without it)
# 5. pytest                                  # unit tests
# 6. python -m graph.pipeline --dry-run      # full pipeline, no orders placed
# 7. python scripts/seed_demo.py && cd dashboard && npm install && npm run dev
